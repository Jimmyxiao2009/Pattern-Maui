<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pattern.Maui.MainPage"
             BackgroundColor="{StaticResource PageBackground}">
    <Grid RowDefinitions="46,*,30" BackgroundColor="{StaticResource PageBackground}">
        <!-- Desktop Title Bar: deliberately quiet so the amber eye and status do the signaling. -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource SurfaceBackground}" Stroke="{StaticResource Line}" StrokeThickness="1" Padding="18,0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <!-- Amber Eye -->
                    <Border WidthRequest="15" HeightRequest="15" StrokeThickness="0" BackgroundColor="{StaticResource Accent}" StrokeShape="RoundRectangle 8" VerticalOptions="Center">
                        <Label Text="·" TextColor="{StaticResource PageBackground}" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                    </Border>
                    <Label Text="Pattern" FontSize="13" FontAttributes="Bold" VerticalTextAlignment="Center" />
                    <BoxView WidthRequest="1" HeightRequest="18" Color="{StaticResource Line}" VerticalOptions="Center" />
                    <Label x:Name="ViewTitleLabel" Text="对话" TextColor="{StaticResource TextFaint}" FontSize="12" VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
                <Label Grid.Column="2" Text="PERSONAL AGENT WORKSPACE" TextColor="{StaticResource TextFaint}" FontSize="9" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                <Button Grid.Column="3" Text="重连" Style="{StaticResource QuietButton}" Clicked="OnReconnectClicked" VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- Workspace: Rail + Content -->
        <Grid Grid.Row="1" ColumnDefinitions="72,*" BackgroundColor="{StaticResource SurfaceBackground}">
            <!-- Navigation Rail -->
            <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceBackground}" Stroke="{StaticResource Line}" StrokeThickness="1" Padding="8,14">
                <ScrollView VerticalScrollBarVisibility="Never">
                    <VerticalStackLayout x:Name="NavigationBar" Spacing="7" />
                </ScrollView>
            </Border>
            <!-- Content Host -->
            <Border Grid.Column="1" BackgroundColor="{StaticResource SurfaceBackground}" StrokeThickness="0" Padding="0">
                <ContentView x:Name="ContentHost" />
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" BackgroundColor="{StaticResource SurfaceBackground}" Stroke="{StaticResource Line}" StrokeThickness="1" Padding="16,0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="7">
                <Ellipse WidthRequest="7" HeightRequest="7" Fill="{StaticResource Accent}" VerticalOptions="Center" />
                <Label x:Name="StatusLabel" Grid.Column="1" Text="正在启动运行时…" TextColor="{StaticResource TextFaint}" FontSize="10" VerticalTextAlignment="Center" />
                <Label Grid.Column="3" Text="PATTERN · 0.4.0" TextColor="{StaticResource TextFaint}" FontFamily="Consolas" FontSize="10" VerticalTextAlignment="Center" />
            </Grid>
        </Border>

        <!-- Quick Window overlay: the Windows hotkey opens the same compact
             companion surface as the old Tauri QuickWindow route. -->
        <ContentView x:Name="QuickWindowHost" Grid.RowSpan="3" IsVisible="False" ZIndex="20" HorizontalOptions="Center" VerticalOptions="Start" Margin="0,58,0,0" />
    </Grid>
</ContentPage>
