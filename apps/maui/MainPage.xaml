<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pattern.Maui.MainPage"
             BackgroundColor="{StaticResource PageBackground}">
    <Grid Padding="20" RowDefinitions="Auto,Auto,*" RowSpacing="14">
        <Grid ColumnDefinitions="*,Auto">
            <VerticalStackLayout Spacing="1">
                <Label Text="Pattern" FontSize="28" FontAttributes="Bold" />
                <Label x:Name="StatusLabel" Text="正在启动运行时…" TextColor="#9BA8BD" />
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="重连" Clicked="OnReconnectClicked" />
        </Grid>
        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout x:Name="NavigationBar" Spacing="8" />
        </ScrollView>
        <ContentView x:Name="ContentHost" Grid.Row="2" />
    </Grid>
</ContentPage>
