<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pattern.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PageBackground">#101827</Color>
            <Color x:Key="PanelBackground">#192235</Color>
            <Color x:Key="Accent">#8AB4F8</Color>
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="#E8EDF7" />
            </Style>
            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="#F8FAFC" />
                <Setter Property="PlaceholderColor" Value="#9BA8BD" />
                <Setter Property="BackgroundColor" Value="#253149" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
