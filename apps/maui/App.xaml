<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pattern.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ============================================ -->
            <!-- Color Tokens - Graphite + Amber Theme          -->
            <!-- ============================================ -->
            <Color x:Key="PageBackground">#0E0D10</Color>
            <Color x:Key="SurfaceBackground">#151419</Color>
            <Color x:Key="PanelBackground">#1B1A20</Color>
            <Color x:Key="ElevatedBackground">#242229</Color>
            <!-- Line colors using rgba from CSS: rgba(255,255,255,.08) = #1E1D22, rgba(255,255,255,.15) = #3A3940 -->
            <Color x:Key="Line">#1E1D22</Color>
            <Color x:Key="LineStrong">#3A3940</Color>
            <Color x:Key="TextPrimary">#EBE8E2</Color>
            <Color x:Key="TextMuted">#96919C</Color>
            <Color x:Key="TextFaint">#625F69</Color>
            <Color x:Key="Accent">#E7A23B</Color>
            <Color x:Key="AccentHigh">#F1B95D</Color>
            <!-- rgba(231,162,59,.12) = #1E1A0D, rgba(231,162,59,.36) = #4D3A1A -->
            <Color x:Key="AccentWash">#1E1A0D</Color>
            <Color x:Key="AccentLine">#4D3A1A</Color>
            <Color x:Key="Positive">#4DB380</Color>
            <!-- rgba(77,179,128,.13) = #0D1E16 -->
            <Color x:Key="PositiveWash">#0D1E16</Color>
            <Color x:Key="Info">#70A3DC</Color>
            <!-- rgba(112,163,220,.13) = #0D1A2E -->
            <Color x:Key="InfoWash">#0D1A2E</Color>
            <Color x:Key="Danger">#E05B50</Color>
            <!-- rgba(224,91,80,.13) = #1E0D0D -->
            <Color x:Key="DangerWash">#1E0D0D</Color>

            <!-- ============================================ -->
            <!-- Global Control Styles                        -->
            <!-- ============================================ -->
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="FontFamily" Value="Segoe UI" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextFaint}" />
                <Setter Property="BackgroundColor" Value="{StaticResource PanelBackground}" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="HeightRequest" Value="36" />
            </Style>

            <Style TargetType="Editor">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextFaint}" />
                <Setter Property="BackgroundColor" Value="{StaticResource PanelBackground}" />
                <Setter Property="FontFamily" Value="Consolas" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ElevatedBackground}" />
                <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
                <Setter Property="BorderColor" Value="{StaticResource LineStrong}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="12,7" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontFamily" Value="Segoe UI" />
            </Style>

            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                <Setter Property="TextColor" Value="{StaticResource PageBackground}" />
                <Setter Property="BorderColor" Value="{StaticResource Accent}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="QuietButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
                <Setter Property="BorderColor" Value="{StaticResource Line}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="FontSize" Value="11" />
            </Style>

            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource DangerWash}" />
                <Setter Property="TextColor" Value="{StaticResource Danger}" />
                <Setter Property="BorderColor" Value="{StaticResource Danger}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="FontSize" Value="11" />
            </Style>

            <Style x:Key="NavButton" TargetType="Button">
                <Setter Property="WidthRequest" Value="54" />
                <Setter Property="HeightRequest" Value="52" />
                <Setter Property="Padding" Value="2,3" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="TextColor" Value="{StaticResource TextFaint}" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="BorderWidth" Value="0" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentWash}" />
                <Setter Property="TextColor" Value="{StaticResource Accent}" />
            </Style>

            <Style x:Key="CardBorder" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource PanelBackground}" />
                <Setter Property="Stroke" Value="{StaticResource Line}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="7" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Padding" Value="14,11" />
            </Style>

            <Style x:Key="ElevatedCardBorder" TargetType="Border" BasedOn="{StaticResource CardBorder}">
                <Setter Property="BackgroundColor" Value="{StaticResource ElevatedBackground}" />
                <Setter Property="Stroke" Value="{StaticResource LineStrong}" />
            </Style>

            <Style x:Key="ComposerBorder" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource PanelBackground}" />
                <Setter Property="Stroke" Value="{StaticResource LineStrong}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="8" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Padding" Value="12,10" />
            </Style>

            <Style x:Key="MessageBubbleUser" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource PanelBackground}" />
                <Setter Property="Stroke" Value="{StaticResource Line}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="8,8,2,8" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="MaximumWidthRequest" Value="620" />
                <Setter Property="HorizontalOptions" Value="End" />
            </Style>

            <Style x:Key="MessageBubbleAssistant" TargetType="Border">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="MaximumWidthRequest" Value="620" />
                <Setter Property="HorizontalOptions" Value="Start" />
            </Style>

            <Style x:Key="BadgeAmber" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentWash}" />
                <Setter Property="Stroke" Value="{StaticResource AccentLine}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="4" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Padding" Value="6,3" />
            </Style>

            <Style x:Key="BadgeGreen" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource PositiveWash}" />
                <Setter Property="Stroke" Value="{StaticResource Positive}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="4" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Padding" Value="6,3" />
            </Style>

            <Style x:Key="BadgeBlue" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource InfoWash}" />
                <Setter Property="Stroke" Value="{StaticResource Info}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="4" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Padding" Value="6,3" />
            </Style>

            <Style x:Key="BadgeDim" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBackground}" />
                <Setter Property="Stroke" Value="{StaticResource Line}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="4" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Padding" Value="6,3" />
            </Style>

            <Style x:Key="SearchBox" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource PanelBackground}" />
                <Setter Property="Stroke" Value="{StaticResource Line}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="6" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Padding" Value="10,6" />
            </Style>

            <Style x:Key="TabButton" TargetType="Button">
                <Setter Property="HorizontalOptions" Value="Fill" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
                <Setter Property="BorderWidth" Value="0" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="TabButtonActive" TargetType="Button" BasedOn="{StaticResource TabButton}">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentWash}" />
                <Setter Property="TextColor" Value="{StaticResource Accent}" />
            </Style>

            <Style x:Key="PageHeader" TargetType="VerticalStackLayout">
                <Setter Property="Spacing" Value="3" />
                <Setter Property="Padding" Value="42,26,42,4" />
            </Style>

            <Style x:Key="EyebrowLabel" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource Accent}" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontFamily" Value="Consolas" />
            </Style>

            <Style x:Key="PageTitle" TargetType="Label">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>

            <Style x:Key="PageSubtitle" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
                <Setter Property="LineHeight" Value="1.4" />
            </Style>

            <Style x:Key="StatusDot" TargetType="Ellipse">
                <Setter Property="WidthRequest" Value="7" />
                <Setter Property="HeightRequest" Value="7" />
                <Setter Property="Fill" Value="{StaticResource Accent}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="StatusDotGreen" TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
                <Setter Property="Fill" Value="{StaticResource Positive}" />
            </Style>

            <Style x:Key="StatusDotRed" TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
                <Setter Property="Fill" Value="{StaticResource Danger}" />
            </Style>

            <Style x:Key="SwitchStyle" TargetType="Switch">
                <Setter Property="OnColor" Value="{StaticResource Accent}" />
                <Setter Property="ThumbColor" Value="{StaticResource TextPrimary}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
