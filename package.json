{
  "name": "pattern",
  "private": true,
  "version": "0.3.0",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "maui:windows": "pnpm sidecar:build && dotnet run --project apps/maui/Pattern.Maui.csproj -f net10.0-windows10.0.19041.0",
    "maui:windows:debug": "pnpm sidecar:build && dotnet build apps/maui/Pattern.Maui.csproj -f net10.0-windows10.0.19041.0 -p:Configuration=Debug",
    "maui:android": "dotnet build apps/maui/Pattern.Maui.csproj -f net10.0-android",
    "maui:android:debug": "dotnet build apps/maui/Pattern.Maui.csproj -f net10.0-android -p:Configuration=Debug",
    "maui:mac": "dotnet build apps/maui/Pattern.Maui.csproj -f net10.0-maccatalyst",
    "maui:mac:debug": "dotnet build apps/maui/Pattern.Maui.csproj -f net10.0-maccatalyst -p:Configuration=Debug",
    "sidecar:build": "pnpm --dir sidecar build",
    "sidecar:binary": "pnpm --dir sidecar build:binary",
    "sidecar:typecheck": "pnpm --dir sidecar exec tsc --noEmit",
    "sidecar:test": "pnpm --dir sidecar test",
    "build:all": "pnpm sidecar:build",
    "test": "pnpm sidecar:test"
  },
  "devDependencies": {
    "playwright-core": "^1.61.1"
  }
}
